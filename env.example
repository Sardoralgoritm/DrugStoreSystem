# PostgreSQL container credentials
POSTGRES_DB=drugstore
POSTGRES_USER=drugstore
POSTGRES_PASSWORD=change_me_strong_password

# App connection string — must match the above values
DB_CONNECTION=Host=postgres;Port=5432;Database=drugstore;Username=drugstore;Password=change_me_strong_password

# Admin account seeded on first startup
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=Admin@1234_change_me
