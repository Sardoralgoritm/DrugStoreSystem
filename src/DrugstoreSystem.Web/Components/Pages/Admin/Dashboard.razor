@page "/admin/dashboard"
@attribute [Authorize(Roles = "Admin")]
@inject IAdminService AdminService

<PageTitle>Admin Panel</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">Admin Panel</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_dashboard is not null)
{
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="2">
                <MudCardContent Class="text-center pa-6">
                    <MudIcon Icon="@Icons.Material.Filled.LocalPharmacy" Size="Size.Large" Color="Color.Primary" Class="mb-2" />
                    <MudText Typo="Typo.h4">@_dashboard.TotalPharmacies</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Jami dorixonalar</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="2">
                <MudCardContent Class="text-center pa-6">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" Class="mb-2" />
                    <MudText Typo="Typo.h4">@_dashboard.ActivePharmacies</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Faol dorixonalar</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="2">
                <MudCardContent Class="text-center pa-6">
                    <MudIcon Icon="@Icons.Material.Filled.Medication" Size="Size.Large" Color="Color.Info" Class="mb-2" />
                    <MudText Typo="Typo.h4">@_dashboard.TotalMedicines</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Jami dorilar</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="2">
                <MudCardContent Class="text-center pa-6">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Large" Color="Color.Warning" Class="mb-2" />
                    <MudText Typo="Typo.h4">@_dashboard.TotalInventoryItems</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Inventar yozuvlari</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    private AdminDashboardDto? _dashboard;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _dashboard = await AdminService.GetDashboardAsync();
        _loading = false;
    }
}

@using DrugstoreSystem.Application.DTOs
@using DrugstoreSystem.Application.Interfaces
