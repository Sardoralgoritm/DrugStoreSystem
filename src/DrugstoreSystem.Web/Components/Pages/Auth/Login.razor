@page "/auth/login"
@layout EmptyLayout

<PageTitle>Tizimga kirish</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height:100vh">
    <MudCard Style="width:100%;max-width:400px" Elevation="4">
        <MudCardContent Class="pa-8">
            <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-6">
                Tizimga kirish
            </MudText>

            @if (ShowError)
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">
                    Email yoki parol noto'g'ri
                </MudAlert>
            }

            <form method="post" action="/auth/login-handler">
                <AntiforgeryToken />
                <MudTextField T="string" name="email" Label="Email" InputType="InputType.Email"
                              Variant="Variant.Outlined" FullWidth="true" Class="mb-4"
                              Required="true" Placeholder="admin@drugstore.local" />

                <MudTextField T="string" name="password" Label="Parol" InputType="InputType.Password"
                              Variant="Variant.Outlined" FullWidth="true" Class="mb-6"
                              Required="true" />

                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                           Color="Color.Primary" FullWidth="true" Size="Size.Large">
                    Kirish
                </MudButton>
            </form>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    private string? Error { get; set; }

    private bool ShowError => Error == "1";
}
