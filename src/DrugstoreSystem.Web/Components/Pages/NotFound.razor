@page "/not-found"
@layout MainLayout

<PageTitle>Sahifa topilmadi | DorixonaSearch</PageTitle>

<style>
    .notfound-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 80vh;
        text-align: center;
        padding: 2rem;
    }

    .pill-scene {
        position: relative;
        width: 220px;
        height: 220px;
        margin: 0 auto 2rem;
    }

    .pill {
        width: 180px;
        height: 80px;
        border-radius: 40px;
        display: flex;
        overflow: hidden;
        box-shadow: 0 12px 40px rgba(98,0,238,0.25);
        animation: float 3s ease-in-out infinite;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) rotate(-30deg);
    }

    .pill-left {
        width: 50%;
        background: #7c3aed;
    }

    .pill-right {
        width: 50%;
        background: #ede9fe;
    }

    .pill-shadow {
        width: 120px;
        height: 16px;
        background: rgba(98,0,238,0.15);
        border-radius: 50%;
        position: absolute;
        bottom: 10px;
        left: 50%;
        transform: translateX(-50%);
        animation: shadow-pulse 3s ease-in-out infinite;
    }

    .orbit {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 200px;
        height: 200px;
        margin-left: -100px;
        margin-top: -100px;
        border: 2px dashed rgba(124,58,237,0.2);
        border-radius: 50%;
        animation: spin 10s linear infinite;
    }

    .orbit-dot {
        width: 12px;
        height: 12px;
        background: #7c3aed;
        border-radius: 50%;
        position: absolute;
        top: -6px;
        left: 50%;
        margin-left: -6px;
    }

    .four-o-four {
        font-size: 7rem;
        font-weight: 900;
        line-height: 1;
        background: linear-gradient(135deg, #7c3aed, #a78bfa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        letter-spacing: -4px;
        user-select: none;
    }

    .cross-icon {
        position: absolute;
        top: 8px;
        right: 8px;
        font-size: 1.8rem;
        animation: spin 8s linear infinite;
        color: #a78bfa;
    }

    .plus-icon {
        position: absolute;
        bottom: 8px;
        left: 12px;
        font-size: 1.2rem;
        animation: spin 6s linear infinite reverse;
        color: #c4b5fd;
    }

    @@keyframes float {
        0%, 100% { transform: translate(-50%, -50%) rotate(-30deg) translateY(0); }
        50%       { transform: translate(-50%, -50%) rotate(-30deg) translateY(-18px); }
    }

    @@keyframes shadow-pulse {
        0%, 100% { transform: translateX(-50%) scaleX(1);   opacity: 0.5; }
        50%       { transform: translateX(-50%) scaleX(0.6); opacity: 0.2; }
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
    }

    @@keyframes blink {
        0%, 100% { opacity: 1; }
        50%      { opacity: 0.3; }
    }

    .blink {
        animation: blink 2s ease-in-out infinite;
        color: #7c3aed;
    }
</style>

<div class="notfound-wrapper">

    <div class="pill-scene">
        <div class="orbit"><div class="orbit-dot"></div></div>
        <div class="pill">
            <div class="pill-left"></div>
            <div class="pill-right"></div>
        </div>
        <div class="pill-shadow"></div>
        <span class="cross-icon">✚</span>
        <span class="plus-icon">✚</span>
    </div>

    <div class="four-o-four">404</div>

    <MudText Typo="Typo.h5" Class="mt-2 mb-1">
        Voy! Dori topilmadi <span class="blink">💊</span>
    </MudText>

    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-1">
        Siz qidirayotgan sahifa dorixona javonlarida yo'q.
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        Balki noto'g'ri manzil kirittingiz — bosh sahifaga qayting.
    </MudText>

    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               Size="Size.Large"
               StartIcon="@Icons.Material.Filled.Search"
               Href="/"
               Style="border-radius: 24px; padding: 10px 32px;">
        Dori qidirishga qaytish
    </MudButton>

</div>
