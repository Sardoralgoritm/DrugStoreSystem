@page "/pharmacist/profile"
@attribute [Authorize(Roles = "Pharmacist")]
@inject IPharmacyService PharmacyService
@inject ICurrentUser CurrentUser
@inject ISnackbar Snackbar

<PageTitle>Mening dorixonam</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Mening dorixonam</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_notFound)
{
    <MudAlert Severity="Severity.Error">Dorixona ma'lumotlari topilmadi.</MudAlert>
}
else
{
    <MudAlert Severity="Severity.Info" Class="mb-4">
        Koordinatalarni Google Mapsdan olish uchun: Maps → O'ng klik → koordinatlarni nusxalash
    </MudAlert>

    <MudCard Elevation="2">
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_name" Label="Nomi *" Variant="Variant.Outlined"
                                  Error="@(_submitted && string.IsNullOrWhiteSpace(_name))"
                                  ErrorText="Nom kiritilishi shart" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_phone" Label="Telefon" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_address" Label="Manzil *" Variant="Variant.Outlined"
                                  Error="@(_submitted && string.IsNullOrWhiteSpace(_address))"
                                  ErrorText="Manzil kiritilishi shart" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_latitude" Label="Kenglik (Latitude) *"
                                  Variant="Variant.Outlined" InputType="InputType.Number" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_longitude" Label="Uzunlik (Longitude) *"
                                  Variant="Variant.Outlined" InputType="InputType.Number" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_workingHours" Label="Ish vaqti"
                                  Variant="Variant.Outlined" Placeholder="09:00 - 20:00" />
                </MudItem>
            </MudGrid>
        </MudCardContent>
        <MudCardActions Class="px-4 pb-4">
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="Save" Disabled="@_saving">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Saqlash
            </MudButton>
        </MudCardActions>
    </MudCard>
}

@code {
    private string _name = string.Empty;
    private string _address = string.Empty;
    private double _latitude;
    private double _longitude;
    private string? _phone;
    private string? _workingHours;

    private bool _loading = true;
    private bool _notFound;
    private bool _saving;
    private bool _submitted;

    protected override async Task OnInitializedAsync()
    {
        if (CurrentUser.PharmacyId is not { } pharmacyId)
        {
            _notFound = true;
            _loading = false;
            return;
        }

        var pharmacy = await PharmacyService.GetByIdAsync(pharmacyId);
        if (pharmacy is null)
        {
            _notFound = true;
        }
        else
        {
            _name = pharmacy.Name;
            _address = pharmacy.Address;
            _latitude = pharmacy.Latitude;
            _longitude = pharmacy.Longitude;
            _phone = pharmacy.Phone;
            _workingHours = pharmacy.WorkingHours;
        }
        _loading = false;
    }

    private async Task Save()
    {
        _submitted = true;
        if (string.IsNullOrWhiteSpace(_name) || string.IsNullOrWhiteSpace(_address)) return;

        _saving = true;
        try
        {
            await PharmacyService.UpdateAsync(CurrentUser.PharmacyId!.Value,
                new UpdatePharmacyRequest(_name, _address, _latitude, _longitude, _phone, _workingHours));
            Snackbar.Add("O'zgarishlar saqlandi", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}

@using DrugstoreSystem.Application.DTOs
@using DrugstoreSystem.Application.Interfaces
@using DrugstoreSystem.Application.Requests
@using Microsoft.AspNetCore.Authorization
