@page "/medicine/{Id:int}"
@inject IMedicineService MedicineService
@inject IInventoryRepository InventoryRepository
@inject NavigationManager Nav

<PageTitle>Dori ma'lumoti | DorixonaSearch</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">

    <MudButton Variant="Variant.Text"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               Href="/"
               Class="mb-4">
        Qidiruvga qaytish
    </MudButton>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate Color="Color.Primary" />
    }
    else if (_medicine is null)
    {
        <EmptyState Message="Dori topilmadi" />
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="5">
                <MudPaper Elevation="2" Class="pa-4">
                    <MudText Typo="Typo.h5" Class="mb-2">@_medicine.Name</MudText>

                    @if (_medicine.GenericName is not null)
                    {
                        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-1">
                            Generik nomi: @_medicine.GenericName
                        </MudText>
                    }
                    @if (_medicine.NameRu is not null)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-1">
                            Русское название: @_medicine.NameRu
                        </MudText>
                    }

                    <MudDivider Class="my-3" />

                    @if (_medicine.DosageForm is not null)
                    {
                        <MudText Typo="Typo.body2"><b>Shakli:</b> @_medicine.DosageForm.ToUzbek()</MudText>
                    }
                    @if (_medicine.Category is not null)
                    {
                        <MudText Typo="Typo.body2"><b>Kategoriya:</b> @_medicine.Category.Name</MudText>
                    }
                    @if (_medicine.Manufacturer is not null)
                    {
                        <MudText Typo="Typo.body2"><b>Ishlab chiqaruvchi:</b> @_medicine.Manufacturer</MudText>
                    }
                    @if (_medicine.Description is not null)
                    {
                        <MudText Typo="Typo.body2" Class="mt-2">@_medicine.Description</MudText>
                    }

                    @if (_medicine.Synonyms.Any())
                    {
                        <MudDivider Class="my-3" />
                        <MudText Typo="Typo.caption" Class="mb-1">Sinonimlar / savdo nomlari:</MudText>
                        <MudStack Row Wrap="Wrap.Wrap">
                            @foreach (var s in _medicine.Synonyms)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">
                                    @s.Synonym
                                </MudChip>
                            }
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="7">
                <MudText Typo="Typo.h6" Class="mb-2">Mavjud dorixonalar</MudText>

                @if (_pharmacies.Count == 0)
                {
                    <EmptyState Message="Bu dori hozirda hech qaysi dorixonada mavjud emas" />
                }
                else
                {
                    <MudTable Items="@_pharmacies" Dense Hover Elevation="1">
                        <HeaderContent>
                            <MudTh>Dorixona</MudTh>
                            <MudTh>Narxi</MudTh>
                            <MudTh>Miqdor</MudTh>
                            <MudTh>Ish vaqti</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Dorixona">
                                <MudText>@context.PharmacyName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Address</MudText>
                            </MudTd>
                            <MudTd DataLabel="Narxi">@context.Price.ToString("N0") so'm</MudTd>
                            <MudTd DataLabel="Miqdor">
                                @if (context.Quantity < 5)
                                {
                                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">@context.Quantity ta</MudChip>
                                }
                                else
                                {
                                    <MudText>@context.Quantity ta</MudText>
                                }
                            </MudTd>
                            <MudTd DataLabel="Ish vaqti">
                                <MudText Typo="Typo.caption">@(context.WorkingHours ?? "—")</MudText>
                            </MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Map" Size="Size.Small" Color="Color.Primary"
                                               Href="@($"https://www.google.com/maps/search/?api=1&query={context.Latitude},{context.Longitude}")"
                                               Target="_blank" />
                                <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default"
                                               Href="@($"/pharmacy/{context.PharmacyId}")" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudItem>
        </MudGrid>
    }

</MudContainer>

@using DrugstoreSystem.Application.DTOs
@using DrugstoreSystem.Application.Helpers
@using DrugstoreSystem.Application.Interfaces
@using DrugstoreSystem.Domain.Entities

@code {
    [Parameter] public int Id { get; set; }

    private Medicine? _medicine;
    private IReadOnlyList<PharmacyResultDto> _pharmacies = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _medicine = await MedicineService.GetByIdAsync(Id);
        if (_medicine is not null)
            _pharmacies = await InventoryRepository.GetAvailablePharmaciesAsync(Id);
        _loading = false;
    }
}
