@page "/pharmacy/{Id:int}"
@inject IPharmacyService PharmacyService
@inject IInventoryService InventoryService

<PageTitle>Dorixona ma'lumoti | DorixonaSearch</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">

    <MudButton Variant="Variant.Text"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               Href="/"
               Class="mb-4">
        Qidiruvga qaytish
    </MudButton>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate Color="Color.Primary" />
    }
    else if (_pharmacy is null)
    {
        <EmptyState Message="Dorixona topilmadi" />
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="5">
                <MudPaper Elevation="2" Class="pa-4">
                    <MudStack Row AlignItems="AlignItems.Center" Class="mb-2">
                        <MudText Typo="Typo.h5">@_pharmacy.Name</MudText>
                        <MudSpacer />
                        @if (_pharmacy.IsActive)
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small">Faol</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Error" Size="Size.Small">Nofaol</MudChip>
                        }
                    </MudStack>

                    <MudText Typo="Typo.body2" Class="mb-1">
                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Class="mr-1" />
                        @_pharmacy.Address
                    </MudText>

                    @if (_pharmacy.Phone is not null)
                    {
                        <MudText Typo="Typo.body2" Class="mb-1">
                            <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" Class="mr-1" />
                            @_pharmacy.Phone
                        </MudText>
                    }

                    @if (_pharmacy.WorkingHours is not null)
                    {
                        <MudText Typo="Typo.body2" Class="mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                            @_pharmacy.WorkingHours
                        </MudText>
                    }

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Map"
                               Href="@($"https://www.google.com/maps/search/?api=1&query={_pharmacy.Latitude},{_pharmacy.Longitude}")"
                               Target="_blank"
                               FullWidth>
                        Xaritada ko'rish
                    </MudButton>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="7">
                <MudText Typo="Typo.h6" Class="mb-2">Mavjud dorilar</MudText>

                @if (_inventory.Count == 0)
                {
                    <EmptyState Message="Bu dorixonada hozirda dori mavjud emas" />
                }
                else
                {
                    <MudTable Items="@_inventory" Dense Hover Elevation="1">
                        <HeaderContent>
                            <MudTh>Dori nomi</MudTh>
                            <MudTh>Narxi</MudTh>
                            <MudTh>Miqdor</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <MudLink Href="@($"/medicine/{context.MedicineId}")">@context.MedicineName</MudLink>
                                @if (context.GenericName is not null)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary"> (@context.GenericName)</MudText>
                                }
                            </MudTd>
                            <MudTd>@context.Price.ToString("N0") so'm</MudTd>
                            <MudTd>
                                @if (context.Quantity < 5)
                                {
                                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">@context.Quantity ta</MudChip>
                                }
                                else
                                {
                                    <MudText>@context.Quantity ta</MudText>
                                }
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudItem>
        </MudGrid>
    }

</MudContainer>

@using DrugstoreSystem.Application.DTOs
@using DrugstoreSystem.Application.Interfaces

@code {
    [Parameter] public int Id { get; set; }

    private PharmacyDto? _pharmacy;
    private IReadOnlyList<InventoryItemDto> _inventory = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _pharmacy = await PharmacyService.GetByIdAsync(Id);
        if (_pharmacy is not null)
            _inventory = await InventoryService.GetInventoryAsync(Id);
        _loading = false;
    }
}
