@page "/"
@inject ISearchService SearchService
@inject IJSRuntime JS

<PageTitle>Dori qidirish | DorixonaSearch</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">

    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-2">Dori qidirish</MudText>
    <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary" Class="mb-6">
        Dori nomini kiriting — yaqin dorixonalarni topamiz
    </MudText>

    <MudPaper Elevation="2" Class="pa-4 mb-6">
        <MudGrid>
            <MudItem xs="12" sm="8">
                <MudTextField @bind-Value="_query"
                              Placeholder="Masalan: Paracetamol, Aspirin, Амоксициллин..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined"
                              Immediate="false"
                              OnKeyDown="OnKeyDown" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth
                           Size="Size.Large"
                           OnClick="SearchAsync"
                           Disabled="_searching">
                    @if (_searching)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" />
                    }
                    Qidirish
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_searched && _results.Count == 0)
    {
        <EmptyState Message="@($"'{_lastQuery}' bo'yicha hech narsa topilmadi")" />
    }

    @foreach (var result in _results)
    {
        <MudPaper Elevation="1" Class="mb-4 pa-4">
            <MudStack Row AlignItems="AlignItems.Center" Class="mb-2">
                <MudText Typo="Typo.h6">
                    <MudLink Href="@($"/medicine/{result.Medicine.Id}")">@result.Medicine.Name</MudLink>
                </MudText>
                @if (result.Medicine.GenericName is not null)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">@result.Medicine.GenericName</MudChip>
                }
                @if (result.Medicine.CategoryName is not null)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@result.Medicine.CategoryName</MudChip>
                }
                <MudSpacer />
                <MudText Typo="Typo.caption" Color="Color.Secondary">@result.Pharmacies.Count ta dorixona</MudText>
            </MudStack>

            <MudTable Items="@result.Pharmacies" Dense Hover Elevation="0">
                <HeaderContent>
                    <MudTh>Dorixona</MudTh>
                    <MudTh>Narxi</MudTh>
                    <MudTh>Miqdor</MudTh>
                    <MudTh>Ish vaqti</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Dorixona">
                        <MudText>@context.PharmacyName</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Address</MudText>
                    </MudTd>
                    <MudTd DataLabel="Narxi">@context.Price.ToString("N0") so'm</MudTd>
                    <MudTd DataLabel="Miqdor">
                        @if (context.Quantity < 5)
                        {
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">@context.Quantity ta</MudChip>
                        }
                        else
                        {
                            <MudText>@context.Quantity ta</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Ish vaqti">
                        <MudText Typo="Typo.caption">@(context.WorkingHours ?? "—")</MudText>
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Map" Size="Size.Small" Color="Color.Primary"
                                       Href="@($"https://www.google.com/maps/search/?api=1&query={context.Latitude},{context.Longitude}")"
                                       Target="_blank" />
                        <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default"
                                       Href="@($"/pharmacy/{context.PharmacyId}")" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }

</MudContainer>

@using DrugstoreSystem.Application.DTOs
@using DrugstoreSystem.Application.Interfaces

@code {
    private string _query = string.Empty;
    private string _lastQuery = string.Empty;
    private bool _searching;
    private bool _searched;
    private IReadOnlyList<SearchResultDto> _results = [];

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAsync();
    }

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_query) || _query.Trim().Length < 2) return;

        _searching = true;
        _lastQuery = _query.Trim();
        try
        {
            _results = await SearchService.SearchAsync(_lastQuery);
            _searched = true;
        }
        finally
        {
            _searching = false;
        }
    }
}
