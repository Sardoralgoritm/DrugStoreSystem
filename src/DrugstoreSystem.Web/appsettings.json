{
  "ConnectionStrings": {
    "DefaultConnection": "SEE USER-SECRETS"
  },
  "Seed": {
    "AdminEmail": "admin@drugstore.local",
    "AdminPassword": "SEE USER-SECRETS"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/drugstore-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
